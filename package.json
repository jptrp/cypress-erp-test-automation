{
  "name": "cypress-erp-test-automation",
  "version": "1.0.0",
  "description": "MVP ERP System with Comprehensive Test Automation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:ui && npm run test:api",
    "test:ui": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/api/**/*.cy.js'",
    "cypress:open": "cypress open",
    "build": "echo 'Build completed'",
    "lint": "eslint ."
  },
  "keywords": [
    "erp",
    "cypress",
    "testing",
    "automation",
    "acumatica"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "launchdarkly-node-server-sdk": "^7.0.0"
  },
  "devDependencies": {
    "cypress": "^13.6.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "@cypress/grep": "^4.0.1"
  }
}
